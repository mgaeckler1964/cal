  object selectWortSql: TQuery
    DatabaseName = 'CAL'
    SQL.Strings = (
      'select worte.id, worte.deutsch, worte.fremdsprache, worte.fehler'
      'from worte, w_list'
      'where worte.id = w_list.wort and'
      'w_list.lektion = :lektionId and'
      'worte.Fehler >= :minFehlerCount and'
      'worte.id <> :lastWordId'
      ' '
      ' ')
    Left = 224
    Top = 16
    ParamData = <
      item
        DataType = ftInteger
        Name = 'lektionId'
        ParamType = ptUnknown
        Value = 0
      end
      item
        DataType = ftInteger
        Name = 'minFehlerCount'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'lastWordId'
        ParamType = ptUnknown
      end>
  end
  object resultSql: TQuery
    DatabaseName = 'CAL'
    SQL.Strings = (
      'select deutsch, fremdsprache'
      'from worte'
      'where (deutsch = :deutsch or'
      'fremdsprache = :fremdsprache)'
      'and sprache = :sprache')
    Left = 40
    Top = 136
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'deutsch'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'fremdsprache'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'sprache'
        ParamType = ptUnknown
      end>
  end
  object updateSql: TQuery
    DatabaseName = 'CAL'
    SQL.Strings = (
      'update worte'
      'set fehler = :fehlercount,'
      'frageDatum = :newDate'
      'where id = :wortId')
    Left = 40
    Top = 192
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'fehlercount'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'newDate'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'wortId'
        ParamType = ptUnknown
      end>
  end
  object incFehler: TQuery
    DatabaseName = 'CAL'
    SQL.Strings = (
      'update worte set fehler = fehler +1 where fehler < 5'
      ' ')
    Left = 280
    Top = 16
  end
  object countErrorSQL: TQuery
    DatabaseName = 'CAL'
    SQL.Strings = (
      'select'#9'sum(worte.fehler) as errorCount,'
      #9#9'count(*) as wordCount'
      'from'#9'worte, w_list'
      'where'#9'worte.id = w_list.wort and'
      #9#9'w_list.lektion = :lektionId and'
      #9#9'worte.fehler > 0'
      ' ')
    Left = 224
    Top = 144
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'lektionId'
        ParamType = ptUnknown
      end>
  end
